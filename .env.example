# Copy to .env and adjust as needed. Real environment variables always win.

# --- Full database URL (takes precedence over the POSTGRES_* values below) ---
# Django parses this via dj-database-url. `postgres://` and the SQLAlchemy
# `postgresql+psycopg2://` form are both normalised automatically.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tasks

# --- Individual PostgreSQL settings (used only if DATABASE_URL is unset) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tasks
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Django ---
# Generate a real one for anything non-local: `python -c "import secrets; print(secrets.token_urlsafe(50))"`
DJANGO_SECRET_KEY=dev-insecure-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
